#. TRANSLATORS: the application name
#. set the title
#. TRANSLATORS: Application window title
#: data/appdata/org.gnome.MultiWriter.appdata.xml.in:8
#: data/org.gnome.MultiWriter.desktop.in:2 src/gmw-main.c:772
#: src/gmw-main.ui:98
msgid "MultiWriter"
msgstr "MultiWriter"

#. TRANSLATORS: one-line description for the app
#: data/appdata/org.gnome.MultiWriter.appdata.xml.in:10
#: data/org.gnome.MultiWriter.desktop.in:3 src/gmw-main.c:1246
msgid "Write an ISO file to multiple USB devices at once"
msgstr "ISO файлын бір уақытта бірнеше USB құрылғысына жазу"

#. TRANSLATORS: AppData description marketing paragraph
#: data/appdata/org.gnome.MultiWriter.appdata.xml.in:13
msgid ""
"GNOME MultiWriter can be used to write an ISO file to multiple USB devices "
"at once. Supported drive sizes are between 1GB and 32GB."
msgstr ""
"GNOME MultiWriter көмегімен бір ISO файлын бір уақытта бірнеше USB "
"құрылғысына жазуға болады. Қолдау көрсетілетін диск өлшемдері 1 ГБ және 32 "
"ГБ аралығында."

#. TRANSLATORS: QA refers to quality assurance, aka people testing stuff,
#. GNOME refers to the desktop environment
#: data/appdata/org.gnome.MultiWriter.appdata.xml.in:20
msgid ""
"MultiWriter may be useful for QA testing, to create a GNOME Live image for "
"a code sprint or to create hundreds of LiveUSB drives for a trade show."
msgstr ""
"MultiWriter сапаны тексеру (QA) үшін, код спринтіне арналған GNOME Live "
"бейнесін жасау немесе көрмеге жүздеген LiveUSB дискін дайындау үшін пайдалы "
"болуы мүмкін."

#. TRANSLATORS: saturate as in the throughput can get no more
#: data/appdata/org.gnome.MultiWriter.appdata.xml.in:26
msgid ""
"Writing a more than 10 devices simultaneously can easy saturate the USB bus "
"for most storage devices. There are two ways to write more devices in "
"parallel:"
msgstr ""
"10-нан астам құрылғыға бір уақытта жазу көптеген сақтау құрылғылары үшін "
"USB шинасын оңай толтырып тастауы мүмкін. Құрылғыларға параллельді жазудың "
"екі жолы бар:"

#. TRANSLATORS: storage devices refers to the things we're writing to
#: data/appdata/org.gnome.MultiWriter.appdata.xml.in:33
msgid "Use USB 3.0 hubs, even if the storage devices are USB 2.0"
msgstr ""
"Сақтау құрылғылары USB 2.0 болса да, USB 3.0 концентраторларын қолданыңыз"

#. TRANSLATORS: PCIe is the data bus, don't translate please
#: data/appdata/org.gnome.MultiWriter.appdata.xml.in:35
msgid "Install another USB 2.0 PCIe root hub"
msgstr "Тағы бір USB 2.0 PCIe түбірлік концентраторын орнатыңыз"

#. TRANSLATORS: the ColorHug is an open hardware product, don't translate the
#. name
#: data/appdata/org.gnome.MultiWriter.appdata.xml.in:38
msgid ""
"MultiWriter was originally written as part of the ColorHug project but was "
"split off as an independent application in 2015."
msgstr ""
"MultiWriter бастапқыда ColorHug жобасының бөлігі ретінде жазылды, бірақ "
"2015 жылы жеке қолданба ретінде бөлініп шықты."

#. TRANSLATORS: the 1st screenshot caption
#: data/appdata/org.gnome.MultiWriter.appdata.xml.in:47
msgid "Initial screen for the application"
msgstr "Қолданбаның бастапқы экраны"

#. TRANSLATORS: the 2nd screenshot caption
#: data/appdata/org.gnome.MultiWriter.appdata.xml.in:52
msgid "Writing and verifying images"
msgstr "Бейнелерді жазу және тексеру"

#. TRANSLATORS: the 3rd screenshot caption
#: data/appdata/org.gnome.MultiWriter.appdata.xml.in:57
msgid "All devices have been written"
msgstr "Барлық құрылғылар жазылды"

#. TRANSLATORS: these are desktop keywords - remember the trailing ';' :)
#: data/org.gnome.MultiWriter.desktop.in:11
msgid "Image;Writer;ISO;USB;"
msgstr "Бейне;Жазушы;ISO;USB;"

#. TRANSLATORS: schema summary
#: data/org.gnome.MultiWriter.gschema.xml:6
msgid "The filename to write to the USB disks"
msgstr "USB дискілеріне жазылатын файл аты"

#. TRANSLATORS: schema description
#: data/org.gnome.MultiWriter.gschema.xml:8
msgid "The filename of the ISO image to write to the connected USB disks."
msgstr "Қосылған USB дискілеріне жазылатын ISO бейнесінің файл аты."

#. TRANSLATORS: schema summary
#: data/org.gnome.MultiWriter.gschema.xml:13
msgid "The maximum number of threads to use"
msgstr "Пайдаланылатын ағындардың максималды саны"

#. TRANSLATORS: schema description
#: data/org.gnome.MultiWriter.gschema.xml:15
msgid "The maximum number of parallel threads to use when copying data."
msgstr ""
"Деректерді көшіру кезінде пайдаланылатын параллельді ағындардың максималды "
"саны."

#. TRANSLATORS: schema summary
#: data/org.gnome.MultiWriter.gschema.xml:20
msgid "Completely blank drive when writing"
msgstr "Жазу кезінде дискіні толықтай тазарту"

#. TRANSLATORS: schema description
#: data/org.gnome.MultiWriter.gschema.xml:22
msgid "Write the ISO to the drive and then blank the remainder of the drive."
msgstr "ISO-ны дискіге жазып, содан кейін дискінің қалған бөлігін тазарту."

#. TRANSLATORS: schema summary
#: data/org.gnome.MultiWriter.gschema.xml:27
msgid "Verify the ISO image was written correctly"
msgstr "ISO бейнесінің дұрыс жазылғанын тексеру"

#. TRANSLATORS: schema description
#: data/org.gnome.MultiWriter.gschema.xml:29
msgid ""
"Read and verify the ISO image from each device after writing is complete."
msgstr ""
"Жазу аяқталғаннан кейін әрбір құрылғыдан ISO бейнесін оқу және тексеру."

#. TRANSLATORS: schema summary
#: data/org.gnome.MultiWriter.gschema.xml:34
msgid "Inspect the device before writing images"
msgstr "Бейнелерді жазбас бұрын құрылғыны тексеру"

#. TRANSLATORS: schema description
#: data/org.gnome.MultiWriter.gschema.xml:36
msgid ""
"Inspect the device to verify the reported device size is the actual media "
"size."
msgstr ""
"Көрсетілген құрылғы өлшемінің нақты медиа өлшеміне сәйкестігін тексеру үшін "
"құрылғыны қарап шығу."

#. TRANSLATORS: schema summary
#: data/org.gnome.MultiWriter.gschema.xml:41
msgid "Show a warning before writing to a drive"
msgstr "Дискіге жазбас бұрын ескертуді көрсету"

#. TRANSLATORS: schema description
#: data/org.gnome.MultiWriter.gschema.xml:43
msgid ""
"Show a warning dialog confirming that the device contents are to be erased."
msgstr ""
"Құрылғы мазмұны өшірілетінін растайтын ескерту сұхбат терезесін көрсету."

#: data/org.gnome.MultiWriter.policy.in:17
msgid "Check the device"
msgstr "Құрылғыны тексеру"

#: data/org.gnome.MultiWriter.policy.in:18
msgid "Authentication is required to probe the device"
msgstr "Құрылғыны тексеру үшін аутентификация қажет"

#. TRANSLATORS: The image has been written and verified to
#. * *one* device, not all
#: src/gmw-device.c:211
msgid "Written successfully"
msgstr "Сәтті жазылды"

#. TRANSLATORS: we're writing the image to the device
#. * and we now know the speed
#: src/gmw-device.c:219
#, c-format
msgid "Writing at %.1f MB/s…"
msgstr "%.1f МБ/с жылдамдығымен жазылуда…"

#. TRANSLATORS: we're writing the image to the USB device
#: src/gmw-device.c:223
msgid "Writing…"
msgstr "Жазылуда…"

#. TRANSLATORS: We're verifying the USB device contains
#. * the correct image data and we now know the speed
#: src/gmw-device.c:232
#, c-format
msgid "Verifying at %.1f MB/s…"
msgstr "%.1f МБ/с жылдамдығымен тексерілуде…"

#. TRANSLATORS: We're verifying the USB device contains
#. * the correct image data
#: src/gmw-device.c:237
msgid "Verifying…"
msgstr "Тексерілуде…"

#. TRANSLATORS: This is a generic no-name USB flash disk
#: src/gmw-device.c:294
msgid "USB Flash Drive"
msgstr "USB флеш-жинақтағышы"

#. TRANSLATORS: window title renaming labels
#: src/gmw-main.c:263
msgid "New hub label"
msgstr "Жаңа концентратор белгісі"

#. TRANSLATORS: the application name
#. TRANSLATORS: the application name for the about UI
#. TRANSLATORS: A program to copy the LiveUSB image onto USB hardware
#: src/gmw-main.c:418 src/gmw-main.c:1243 src/gmw-main.c:1681
msgid "GNOME MultiWriter"
msgstr "GNOME MultiWriter"

#. TRANSLATORS: the success sound description
#: src/gmw-main.c:420
msgid "Image written successfully"
msgstr "Бейне сәтті жазылды"

#. TRANSLATORS: copy aborted
#: src/gmw-main.c:523 src/gmw-main.c:563 src/gmw-main.c:666 src/gmw-main.c:701
msgid "Cancelled"
msgstr "Бас тартылды"

#. TRANSLATORS: we couldn't open the ISO file the user chose
#: src/gmw-main.c:919 src/gmw-main.c:933
msgid "Failed to open"
msgstr "Ашу сәтсіз аяқталды"

#. TRANSLATORS: window title for the file-chooser, file is an ISO
#: src/gmw-main.c:950
msgid "Choose the file to write"
msgstr "Жазылатын файлды таңдаңыз"

#. TRANSLATORS: button title
#. TRANSLATORS: button to cancel a copy process
#: src/gmw-main.c:954 src/gmw-main.ui:115
msgid "Cancel"
msgstr "Бас тарту"

#. TRANSLATORS: button title
#: src/gmw-main.c:956
msgid "Import"
msgstr "Импорттау"

#. TRANSLATORS: the file filter description, e.g. *.iso
#: src/gmw-main.c:960
msgid "ISO files"
msgstr "ISO файлдары"

#. TRANSLATORS: error dialog title:
#. * we probably didn't authenticate
#: src/gmw-main.c:1104 src/gmw-main.c:1123
msgid "Failed to copy"
msgstr "Көшіру сәтсіз аяқталды"

#. TRANSLATORS: the inhibit reason
#: src/gmw-main.c:1140
msgid "Writing ISO to devices"
msgstr "ISO-ны құрылғыларға жазу"

#. TRANSLATORS: window title for the warning dialog
#: src/gmw-main.c:1187
msgid "Write to all disks?"
msgstr "Барлық дискілерге жазу керек пе?"

#. TRANSLATORS: check that we can nuke everything from all disks
#: src/gmw-main.c:1192
msgid "All data on the drives will be deleted."
msgstr "Дискілердегі барлық деректер өшіріледі."

#. TRANSLATORS: if the image file is smaller than the disks and
#. * we've disabled wiping the device we only write enough data
#. * to transfer the image
#: src/gmw-main.c:1197
msgid "The ISO file is smaller than the disk capacity."
msgstr "ISO файлы дискінің сыйымдылығынан кіші."

#. TRANSLATORS: this could leave your personal files on the drive
#: src/gmw-main.c:1202
msgid ""
"Some of the current contents of the drives could be still found using "
"forensic tools even after copying."
msgstr ""
"Көшіруден кейін де дискілердің кейбір мазмұнын криминалистикалық "
"құралдармен табуға болады."

#. TRANSLATORS: button text for the warning dialog
#: src/gmw-main.c:1209
msgid "I Understand"
msgstr "Мен түсінемін"

#. TRANSLATORS: the title of the about window
#: src/gmw-main.c:1241
msgid "About GNOME MultiWriter"
msgstr "GNOME MultiWriter туралы"

#. TRANSLATORS: you can put your name here :)
#: src/gmw-main.c:1251
msgid "translator-credits"
msgstr "Baurzhan Muftakhidinov <baurthefirst@gmail.com>"

#. TRANSLATORS: a switch label: verify the image by
#. * reading back the original image from the device
#: src/gmw-main.c:1298
msgid "Verify"
msgstr "Тексеру"

#. TRANSLATORS: a switch label: we write zeros after
#. * the image so it erases the entire device
#: src/gmw-main.c:1304
msgid "Wipe"
msgstr "Тазарту"

#. TRANSLATORS: a switch label: we check the device
#. * is actually the size it says it is
#: src/gmw-main.c:1310
msgid "Probe"
msgstr "Тексеріп көру"

#. TRANSLATORS: command line option
#: src/gmw-main.c:1665
msgid "Allow renaming the labels on hubs"
msgstr "Концентраторлардағы белгілердің атын өзгертуге рұқсат беру"

#. TRANSLATORS: command line option
#: src/gmw-main.c:1668 src/gmw-probe.c:468
msgid "Show extra debugging information"
msgstr "Қосымша жөндеу ақпаратын көрсету"

#. TRANSLATORS: the user has sausages for fingers
#: src/gmw-main.c:1686
msgid "Failed to parse command line options"
msgstr "Командалық жол опцияларын талдау сәтсіз аяқталды"

#. TRANSLATORS: button to start the copy
#: src/gmw-main.ui:102
msgid "Start Copying"
msgstr "Көшіруді бастау"

#. TRANSLATORS: command line option
#: src/gmw-probe.c:471
msgid "Random seed for predictability"
msgstr "Болжамдылық үшін кездейсоқ сан (seed)"
